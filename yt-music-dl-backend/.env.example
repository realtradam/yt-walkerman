# yt-music-dl backend — local config. Copy to .env (gitignored), never commit.

# Port the HTTP + WebSocket server listens on.
YTMDL_PORT=24303

# Directory where downloaded/tagged audio is written.
YTMDL_OUTPUT_DIR=./output

# Default audio format: "flac" or "mp3".
YTMDL_FORMAT=flac

# Path to the yt-dlp binary (if not on PATH). bin/install-yt-dlp fetches it.
# YTMDL_YTDLP_PATH=./bin/yt-dlp

# Path to ffmpeg (if not on PATH).
# YTMDL_FFMPEG_PATH=ffmpeg

# SponsorBlock API base URL (public default).
YTMDL_SPONSORBLOCK_API=https://sponsor.ajay.app
